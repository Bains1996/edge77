# Edge77 Environment Variables
# Copy this to .env and fill in your values

# AI Provider (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database (Supabase)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_service_role_key_here

# Authentication
INTERNAL_API_TOKEN=your_internal_api_token_here

# Email Provider (Priority: SES > Gmail > Brevo > SendGrid)
# Option 1: Amazon SES (BEST - recommended, ~$0.10/1000 emails)
AWS_SES_ACCESS_KEY=your_aws_access_key_here
AWS_SES_SECRET_KEY=your_aws_secret_key_here
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=disputes@edge77.com
AWS_SES_FROM_NAME=EDGE77 Audit Division

# Option 2: Gmail SMTP (FREE fallback, 500/day limit)
GMAIL_ADDRESS=axalglobalinc@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here
GMAIL_FROM_NAME=EDGE77 Audit Division

# Option 3: Brevo (FREE tier, 300/day limit)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=audit@edge77.com
BREVO_FROM_NAME=EDGE77 Audit Division

# Option 4: SendGrid (FREE tier, 100/day limit)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=audit@edge77.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# File Upload
MAX_PDF_SIZE_MB=20

# Logging
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=production
